;; Edge build (docs/adr/0002-http-edge-loan-intake.md) -- mirrors
;; cloud-itonami-commitment-ledger's own shadow-cljs.edn :edge-api build
;; (:target :esm, one shared bundle, thin functions/api/**.js re-export
;; shims). REBUILD COMMAND: `npx shadow-cljs release edge-api` -- NOT
;; `compile` (same caveat that repo's shadow-cljs.edn documents: `compile`'s
;; dev-mode artifact imports a machine-local path and cannot load standalone
;; on a Cloudflare Pages Function's runtime).
;; :dev composed alongside :cljs -- see cloud-itonami-commitment-ledger's
;; identical shadow-cljs.edn comment (same fleet, same fix, same reasoning):
;; without it, shadow-cljs's own classpath resolution silently compiles
;; against the STALE gitlibs-pinned io.github.kotoba-lang/langchain (via
;; langgraph-clj's transitive dep), predating `kotoba-api-async`.
{:deps {:aliases [:dev :cljs]}
 :builds
 {:edge-api
  {:target :esm
   :output-dir "functions/edge"
   :modules {:loan-edge-core
             {:exports {intakeOnRequestPost credit.edge.loan-endpoints/on-request-post-intake
                        applicationOnRequestGet credit.edge.loan-endpoints/on-request-get-application}}}
   :compiler-options {:output-feature-set :es2020 :infer-externs :auto}}}}
