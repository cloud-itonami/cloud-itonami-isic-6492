{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the com-junkawasaki org of this workspace. This repo is standalone
 ;; (forkable outside the workspace); the :local/root paths only resolve
 ;; inside the monorepo checkout — a standalone fork should override them
 ;; with git coordinates.
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain-clj to local checkout.
  ;; TWO distinct maven coordinates resolve to this same physical repo in
  ;; this dep graph: io.github.com-junkawasaki/langchain-clj AND
  ;; io.github.kotoba-lang/langchain (langgraph-clj's OWN declared
  ;; coordinate, git-SHA-pinned) -- see the identical fix + full
  ;; reasoning in cloud-itonami-commitment-ledger's deps.edn (same
  ;; migration, same fleet, same dep graph shape). Without overriding
  ;; BOTH, `clojure -M:dev:test` silently loads a STALE gitlibs-pinned
  ;; `langchain/kotoba_db.cljc` predating `kotoba-api-async` instead of
  ;; this local checkout's copy.
  :dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj
         {:local/root "../../kotoba-lang/langchain"}
         io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "credit.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                      ;; kototama.tender hosts the wasm/affordability.kotoba
                      ;; build (see wasm/README.md) -- test-only, the actor's
                      ;; own runtime code has no wasm/host dependency.
                      io.github.kotoba-lang/kototama
                      {:local/root "../../kotoba-lang/kototama"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; PRIMARY gate: the portable .cljc suite under a real ClojureScript
  ;; host (runtime priority: cljs first, JVM compat). The JVM-only
  ;; wasm.affordability-test (kototama.tender/Chicory) is excluded --
  ;; see credit.portable-cljs-test-runner's docstring.
  ;;   clojure -Sdeps '{:paths ["src" "test"]}' -M:dev:cljs \
  ;;     -m cljs.main --target node -m credit.portable-cljs-test-runner
  ;; Also supplies shadow-cljs.edn's :edge-api build (docs/adr/0002-http-
  ;; edge-loan-intake.md) -- same pattern cloud-itonami-commitment-
  ;; ledger's own deps.edn :cljs alias uses.
  :cljs {:extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}
                      thheller/shadow-cljs {:mvn/version "2.28.20"}}}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
